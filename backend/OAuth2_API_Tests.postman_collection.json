      "item": [
        {
          "name": "Initiate Google OAuth2 Login",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/oauth2/authorization/google",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["oauth2", "authorization", "google"]
            },
            "description": "Redirects to Google login page. After successful login, user will be created/loaded and redirected to frontend."
          }
        }
      ]
    },
