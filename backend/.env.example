# Copy this file to ".env" (same folder as pom.xml). Spring Boot reads it on startup via dotenv-java.

# Database Configuration
DB_URL=jdbc:mysql://localhost:3306/smart_campus
DB_USERNAME=root
DB_PASSWORD=Navo2002@

# Server Configuration
PORT=8080

# JWT Configuration (Generate a secure 256-bit secret key)
JWT_SECRET=your-secret-key-change-this-in-production-minimum-256-bits-required

# OAuth2 Google Configuration
# Get these from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Active Profile (dev/prod)
SPRING_PROFILES_ACTIVE=dev
