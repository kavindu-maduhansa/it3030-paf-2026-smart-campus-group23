{
  "info": {
    "name": "Smart Campus API",
    "description": "Complete API collection for Smart Campus Operations Hub",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login with Google OAuth",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/google",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "google"]
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me"]
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"your-refresh-token\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "refresh"]
            }
          }
        }
      ]
    },
    {
      "name": "Resources (Module A)",
      "item": [
        {
          "name": "Get All Resources",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/resources",
              "host": ["{{baseUrl}}"],
              "path": ["resources"]
            }
          }
        },
        {
          "name": "Get Resource by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/resources/1",
              "host": ["{{baseUrl}}"],
              "path": ["resources", "1"]
            }
          }
        },
        {
          "name": "Search Resources",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/resources/search?type=LECTURE_HALL&status=ACTIVE&location=Building A&minCapacity=50",
              "host": ["{{baseUrl}}"],
              "path": ["resources", "search"],
              "query": [
                { "key": "type", "value": "LECTURE_HALL" },
                { "key": "status", "value": "ACTIVE" },
                { "key": "location", "value": "Building A" },
                { "key": "minCapacity", "value": "50" }
              ]
            }
          }
        },
        {
          "name": "Create Resource [ADMIN]",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Lecture Hall B\",\n  \"description\": \"Large lecture hall with modern facilities\",\n  \"type\": \"LECTURE_HALL\",\n  \"capacity\": 150,\n  \"location\": \"Building A, Floor 2\",\n  \"status\": \"ACTIVE\",\n  \"availabilityStart\": \"08:00:00\",\n  \"availabilityEnd\": \"18:00:00\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/resources",
              "host": ["{{baseUrl}}"],
              "path": ["resources"]
            }
          }
        },
        {
          "name": "Update Resource [ADMIN]",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Lecture Hall B - Updated\",\n  \"status\": \"OUT_OF_SERVICE\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/resources/1",
              "host": ["{{baseUrl}}"],
              "path": ["resources", "1"]
            }
          }
        },
        {
          "name": "Delete Resource [ADMIN]",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/resources/1",
              "host": ["{{baseUrl}}"],
              "path": ["resources", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "Bookings (Module B)",
      "item": [
        {
          "name": "Get All Bookings",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/bookings",
              "host": ["{{baseUrl}}"],
              "path": ["bookings"]
            }
          }
        },
        {
          "name": "Get My Bookings",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/bookings/my",
              "host": ["{{baseUrl}}"],
              "path": ["bookings", "my"]
            }
          }
        },
        {
          "name": "Create Booking",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"resourceId\": 1,\n  \"bookingDate\": \"2026-04-15\",\n  \"startTime\": \"09:00:00\",\n  \"endTime\": \"11:00:00\",\n  \"purpose\": \"Software Engineering Lecture\",\n  \"expectedAttendees\": 75\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/bookings",
              "host": ["{{baseUrl}}"],
              "path": ["bookings"]
            }
          }
        },
        {
          "name": "Approve Booking [ADMIN]",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"comment\": \"Booking approved. Please ensure proper usage.\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/bookings/1/approve",
              "host": ["{{baseUrl}}"],
              "path": ["bookings", "1", "approve"]
            }
          }
        },
        {
          "name": "Reject Booking [ADMIN]",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Resource is under maintenance during requested time.\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/bookings/1/reject",
              "host": ["{{baseUrl}}"],
              "path": ["bookings", "1", "reject"]
            }
          }
        },
        {
          "name": "Cancel Booking",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/bookings/1/cancel",
              "host": ["{{baseUrl}}"],
              "path": ["bookings", "1", "cancel"]
            }
          }
        }
      ]
    },
    {
      "name": "Tickets (Module C)",
      "item": [
        {
          "name": "Get All Tickets",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/tickets?status=OPEN&priority=HIGH",
              "host": ["{{baseUrl}}"],
              "path": ["tickets"],
              "query": [
                { "key": "status", "value": "OPEN" },
                { "key": "priority", "value": "HIGH" }
              ]
            }
          }
        },
        {
          "name": "Create Ticket with Attachments",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "title",
                  "value": "Projector not working",
                  "type": "text"
                },
                {
                  "key": "description",
                  "value": "The projector in Lecture Hall A is not turning on",
                  "type": "text"
                },
                {
                  "key": "category",
                  "value": "EQUIPMENT_FAILURE",
                  "type": "text"
                },
                {
                  "key": "priority",
                  "value": "HIGH",
                  "type": "text"
                },
                {
                  "key": "resourceId",
                  "value": "1",
                  "type": "text"
                },
                {
                  "key": "location",
                  "value": "Building A, Floor 1",
                  "type": "text"
                },
                {
                  "key": "contactDetails",
                  "value": "john.doe@example.com",
                  "type": "text"
                },
                {
                  "key": "files",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/tickets",
              "host": ["{{baseUrl}}"],
              "path": ["tickets"]
            }
          }
        },
        {
          "name": "Assign Ticket [ADMIN]",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"technicianId\": 3\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/tickets/1/assign",
              "host": ["{{baseUrl}}"],
              "path": ["tickets", "1", "assign"]
            }
          }
        },
        {
          "name": "Update Ticket Status",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"IN_PROGRESS\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/tickets/1/status",
              "host": ["{{baseUrl}}"],
              "path": ["tickets", "1", "status"]
            }
          }
        },
        {
          "name": "Add Comment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"I've checked the projector. The power cable is loose.\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/tickets/1/comments",
              "host": ["{{baseUrl}}"],
              "path": ["tickets", "1", "comments"]
            }
          }
        }
      ]
    },
    {
      "name": "Notifications (Module D)",
      "item": [
        {
          "name": "Get My Notifications",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/notifications",
              "host": ["{{baseUrl}}"],
              "path": ["notifications"]
            }
          }
        },
        {
          "name": "Get Unread Count",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/notifications/unread",
              "host": ["{{baseUrl}}"],
              "path": ["notifications", "unread"]
            }
          }
        },
        {
          "name": "Mark as Read",
          "request": {
            "method": "PUT",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/notifications/1/read",
              "host": ["{{baseUrl}}"],
              "path": ["notifications", "1", "read"]
            }
          }
        },
        {
          "name": "Mark All as Read",
          "request": {
            "method": "PUT",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/notifications/read-all",
              "host": ["{{baseUrl}}"],
              "path": ["notifications", "read-all"]
            }
          }
        }
      ]
    }
  ]
}
